{
  "name": "create-rsbuild",
  "version": "2.0.5",
  "description": "Create a new Rsbuild project",
  "homepage": "https://rsbuild.rs",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsbuild",
    "directory": "packages/create-rsbuild"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "create-rsbuild": "./bin.js"
  },
  "files": [
    "template-*",
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "rslib --syntax es2023",
    "dev": "rslib --syntax es2023 -w",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "create-rstack": "2.1.1"
  },
  "devDependencies": {
    "@rsbuild/core": "workspace:*",
    "@rsbuild/plugin-babel": "workspace:*",
    "@rsbuild/plugin-preact": "workspace:*",
    "@rsbuild/plugin-react": "workspace:*",
    "@rsbuild/plugin-solid": "workspace:*",
    "@rsbuild/plugin-svelte": "workspace:*",
    "@rsbuild/plugin-vue": "workspace:*",
    "@rslib/core": "0.21.3",
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
