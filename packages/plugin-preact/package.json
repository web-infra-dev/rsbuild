{
  "name": "@rsbuild/plugin-preact",
  "version": "2.0.0",
  "description": "Preact plugin for Rsbuild",
  "homepage": "https://rsbuild.rs",
  "bugs": {
    "url": "https://github.com/web-infra-dev/rsbuild/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsbuild",
    "directory": "packages/plugin-preact"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "test": "rstest"
  },
  "dependencies": {
    "@prefresh/core": "catalog:",
    "@prefresh/utils": "catalog:",
    "@rspack/plugin-preact-refresh": "catalog:",
    "@swc/plugin-prefresh": "catalog:"
  },
  "devDependencies": {
    "@rsbuild/core": "workspace:*",
    "@rslib/core": "catalog:",
    "@types/node": "catalog:",
    "preact": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rsbuild/core": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  }
}
