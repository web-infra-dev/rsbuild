{
  "name": "@rsbuild/plugin-react",
  "version": "2.0.0-rc.2",
  "description": "React plugin for Rsbuild",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsbuild",
    "directory": "packages/plugin-react"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
