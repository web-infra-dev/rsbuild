exports[`plugin-minimize > should remove specific console when performance.removeConsole is array 1`] = `
[
  SwcJsMinimizerRspackPlugin {
    "_args": [
      {
        "extractComments": true,
        "minimizerOptions": {
          "compress": {
            "pure_funcs": [
              "console.log",
              "console.warn",
            ],
          },
          "format": {
            "asciiOnly": false,
          },
        },
      },
    ],
    "affectedHooks": "compilation",
