// Rstest Snapshot v1

exports[`plugin-minimize > should apply minimizer in production 1`] = `
[
  SwcJsMinimizerRspackPlugin {
    "_args": [
      {
        "extractComments": true,
        "minimizerOptions": {
          "format": {
            "asciiOnly": false,
          },
        },
      },
    ],
    "affectedHooks": "compilation",
    "name": "SwcJsMinimizerRspackPlugin",
  },
  LightningCssMinimizerRspackPlugin {
    "_args": [
      {
        "minimizerOptions": {
          "errorRecovery": true,
          "targets": [
            "chrome >= 107",
            "edge >= 107",
            "firefox >= 104",
            "safari >= 16",
          ],
        },
      },
    ],
    "affectedHooks": undefined,
    "name": "LightningCssMinimizerRspackPlugin",
  },
]
`;

exports[`plugin-minimize > should dropConsole when performance.removeConsole is true 1`] = `
