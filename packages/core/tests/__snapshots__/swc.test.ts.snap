exports[`plugin-swc > should apply environment config correctly 1`] = `
[
  {
    "resolve": {
      "fullySpecified": false,
    },
    "test": /\\\\\\.m\\?js/,
  },
  {
    "dependency": {
      "not": "url",
    },
    "exclude": [
      "src/example",
    ],
    "include": [
      {
        "not": /\\[\\\\\\\\/\\]node_modules\\[\\\\\\\\/\\]/,
      },
      /\\\\\\.\\(\\?:ts\\|tsx\\|jsx\\|mts\\|cts\\)\\$/,
    ],
    "oneOf": [
      {
        "resourceQuery": /\\[\\?&\\]raw\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/source",
      },
      {
        "resolve": {
          "alias": {
            "core-js": "<PNPM_INNER>/core-js",
          },
        },
        "type": "javascript/auto",
        "use": [
          {
            "loader": "builtin:swc-loader",
            "options": {
              "collectTypeScriptInfo": {
                "exportedEnum": false,
                "typeExports": true,
              },
              "env": {
                "coreJs": "3.48",
                "mode": "usage",
                "shippedProposals": true,
                "targets": [
                  "chrome >= 107",
                  "edge >= 107",
                  "firefox >= 104",
                  "safari >= 16",
                ],
              },
              "isModule": "unknown",
              "jsc": {
                "experimental": {
                  "cacheRoot": "<ROOT>/packages/core/node_modules/.cache/.swc",
                  "keepImportAttributes": true,
                },
                "externalHelpers": true,
                "output": {
                  "charset": "utf8",
                },
                "parser": {
                  "decorators": true,
                  "syntax": "typescript",
                  "tsx": false,
                },
                "transform": {
                  "decoratorVersion": "2022-03",
                  "legacyDecorator": false,
                },
              },
              "transformImport": [
                {
                  "libraryName": "foo",
                },
              ],
            },
          },
        ],
      },
    ],
    "test": /\\\\\\.\\(\\?:js\\|jsx\\|mjs\\|cjs\\|ts\\|tsx\\|mts\\|cts\\)\\$/,
  },
]
`;

