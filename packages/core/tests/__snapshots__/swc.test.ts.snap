// Rstest Snapshot v1

exports[`plugin-swc > should allow \`tools.swc\` to be a function 1`] = `
[
  {
    "resolve": {
      "fullySpecified": false,
    },
    "test": /\\\\\\.m\\?js/,
  },
  {
    "dependency": {
      "not": "url",
    },
    "include": [
      {
        "not": /\\[\\\\\\\\/\\]node_modules\\[\\\\\\\\/\\]/,
      },
      /\\\\\\.\\(\\?:ts\\|tsx\\|jsx\\|mts\\|cts\\)\\$/,
    ],
    "oneOf": [
      {
        "resourceQuery": /\\[\\?&\\]raw\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/source",
      },
      {
        "type": "javascript/auto",
        "use": [
          {
            "loader": "builtin:swc-loader",
            "options": {
              "jsc": {
                "externalHelpers": false,
              },
            },
          },
        ],
      },
    ],
    "test": /\\\\\\.\\(\\?:js\\|jsx\\|mjs\\|cjs\\|ts\\|tsx\\|mts\\|cts\\)\\$/,
  },
]
`;

exports[`plugin-swc > should allow using \`tools.swc\` to configure swc-loader options 1`] = `
[
  {
    "resolve": {
      "fullySpecified": false,
    },
    "test": /\\\\\\.m\\?js/,
  },
  {
    "dependency": {
      "not": "url",
    },
    "include": [
      {
        "not": /\\[\\\\\\\\/\\]node_modules\\[\\\\\\\\/\\]/,
      },
      /\\\\\\.\\(\\?:ts\\|tsx\\|jsx\\|mts\\|cts\\)\\$/,
    ],
    "oneOf": [
      {
        "resourceQuery": /\\[\\?&\\]raw\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/source",
      },
      {
        "type": "javascript/auto",
        "use": [
          {
            "loader": "builtin:swc-loader",
            "options": {
              "collectTypeScriptInfo": {
                "exportedEnum": false,
                "typeExports": true,
              },
              "env": {
                "targets": [
                  "chrome >= 107",
                  "edge >= 107",
                  "firefox >= 104",
                  "safari >= 16",
                ],
              },
              "isModule": "unknown",
              "jsc": {
                "experimental": {
                  "cacheRoot": "<ROOT>/packages/core/node_modules/.cache/.swc",
                  "keepImportAttributes": true,
                },
                "externalHelpers": false,
                "output": {
                  "charset": "utf8",
                },
                "parser": {
                  "decorators": true,
                  "syntax": "typescript",
                  "tsx": false,
                },
                "transform": {
                  "decoratorVersion": "2022-03",
                  "legacyDecorator": false,
                },
              },
            },
          },
        ],
      },
    ],
    "test": /\\\\\\.\\(\\?:js\\|jsx\\|mjs\\|cjs\\|ts\\|tsx\\|mts\\|cts\\)\\$/,
  },
]
`;

