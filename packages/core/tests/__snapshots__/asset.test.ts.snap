// Rstest Snapshot v1

exports[`plugin-asset > should add image rules correctly 1`] = `
[
  {
    "oneOf": [
      {
        "generator": {
          "filename": "static/image/[name].[contenthash:10][ext]",
        },
        "resourceQuery": /\\[\\?&\\]url\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/resource",
      },
      {
        "resourceQuery": /\\[\\?&\\]inline\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/inline",
      },
      {
        "resourceQuery": /\\[\\?&\\]raw\\(\\?:&\\|=\\|\\$\\)/,
        "type": "asset/source",
      },
      {
        "generator": {
          "filename": "static/image/[name].[contenthash:10][ext]",
        },
        "parser": {
          "dataUrlCondition": {
            "maxSize": 4096,
          },
        },
        "type": "asset",
      },
    ],
    "test": /\\\\\\.\\(\\?:png\\|jpg\\|jpeg\\|pjpeg\\|pjp\\|gif\\|bmp\\|webp\\|ico\\|apng\\|avif\\|tif\\|tiff\\|jfif\\|cur\\)\\$/i,
  },
]
`;

