{
  "extends": "@scripts/config/tsconfig",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@theme": ["./theme"],
      "@components/*": ["./theme/components/*"],
      "@zh/*": ["./docs/zh/*"],
      "@en/*": ["./docs/en/*"],
      "i18n": ["./i18n.json"]
    }
  },
  "mdx": {
    "checkMdx": true
  },
  "include": ["docs", "rstack.config.ts", "theme", "env.d.ts"]
}
